# Required core settings
PAYLOAD_SECRET=replace-with-strong-random-secret
DATABASE_URI=postgres://dainiknewtimes_user:change-me@localhost:5432/dainiknewtimes
NEXT_PUBLIC_SITE_URL=https://www.dainiknewtimes.com

# PostgreSQL (local docker)
POSTGRES_DB=dainiknewtimes
POSTGRES_USER=dainiknewtimes_user
POSTGRES_PASSWORD=change-me

# Crop API safety
EPAPER_CROP_ALLOWED_HOSTS=www.dainiknewtimes.com
EPAPER_CROP_RATE_LIMIT_MAX=30
EPAPER_CROP_FETCH_TIMEOUT_MS=10000
EPAPER_CROP_MAX_BYTES=10485760

# Optional external monitoring webhook
ERROR_MONITOR_WEBHOOK_URL=

# Required when running `npm run seed` for first admin bootstrap
SEED_ADMIN_PASSWORD=

# Optional Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_HEADER=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_IN_ARTICLE=
NEXT_PUBLIC_ADSENSE_SLOT_BETWEEN=
